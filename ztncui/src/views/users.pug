extends users_layout

block users_content
  table.table.table-responsive.table-striped.table-hover
    tr
      th(width='3%')
        = ''
      th(width='15%') Username
      th(width='15%') Role
      th(width='67%')
        = ''
    each user in users
      tr
        td(width='3%')
          a(href='/users/' + user.name + '/delete')
            i.glyphicon.glyphicon-trash
        td(width='15%')
          a(href='/users/' + user.name + '/password') #{user.name}
        td(width='15%')
          if user.role === 'admin'
            span.label.label-danger Admin
          else
            span.label.label-default Normal user
        td(width='67%')
          a(href='/users/' + user.name + '/password') set password

    else
      .alert.alert-info
        strong There are no users on this system
